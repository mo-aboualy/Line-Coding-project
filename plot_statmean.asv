function plot_statmean(ensemble, title_name)
    [num_realizations, num_samples] = size(ensemble);
    
    statistical_mean = sum(ensemble, 1) / num_realizations;
    
    t = 0:10:799*10;
    figure
    plot(t, statistical_mean);
    title(title_name);
    xlabel('Time (ms)');
    ylabel('Mean Amplitude');
    grid on;
end